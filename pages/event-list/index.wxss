.filter-panel {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.filter-panel .section-header {
  border-bottom: none;
  padding-bottom: 0;
  margin-bottom: 0;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
}

.filter-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid var(--border-light);
}

.filter-chip-active {
  background: var(--accent);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 6rpx 16rpx rgba(148, 1, 35, 0.2);
}

.event-card {
  border-top: 6rpx solid var(--secondary);
}

.event-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.event-head-main {
  flex: 1;
  min-width: 0;
}

.event-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--accent-deep);
  letter-spacing: 0.02em;
}

.event-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.event-stats {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: var(--gold-soft);
  font-size: 24rpx;
  color: var(--text-secondary);
}

.stat-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
}
