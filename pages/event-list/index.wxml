<view class="page-shell">
  <view class="hero-card">
    <view class="page-title">我的活动</view>
    <view class="page-subtitle">管理你已经创建的活动，继续编辑、复制、归档或重新发布。</view>
  </view>

  <view class="section-block panel-card panel-body filter-panel">
    <scroll-view class="filter-scroll" scroll-x enable-flex>
      <view class="filter-row">
        <view
          wx:for="{{filters}}"
          wx:key="key"
          class="filter-chip {{filter === item.key ? 'filter-chip-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onSwitchFilter"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <block wx:if="{{loading}}">
    <view class="section-block panel-card panel-body">
      <view class="skeleton-block skeleton-line"></view>
      <view class="skeleton-block skeleton-card"></view>
    </view>
    <view class="section-block panel-card panel-body">
      <view class="skeleton-block skeleton-card"></view>
    </view>
  </block>

  <block wx:elif="{{displayEvents.length}}">
    <view
      wx:for="{{displayEvents}}"
      wx:key="eventId"
      class="section-block panel-card panel-body event-card"
    >
      <view class="event-head">
        <view class="event-head-main">
          <view class="event-name">{{item.name}}</view>
          <view class="event-meta">{{item.typeLabel}} · 更新于 {{item.updatedLabel}}</view>
        </view>
        <view class="{{item.statusMeta.className}}">{{item.statusMeta.label}}</view>
      </view>
      <view class="event-stats">
        <text class="stat-dot"></text>
        <text>{{item.tableCount || 0}} 桌 · {{item.guestCount || 0}} 人</text>
      </view>
      <view class="button-row">
        <button class="cta-button" data-id="{{item.eventId}}" bindtap="onOpenEvent">继续编辑</button>
      </view>
      <view class="link-row">
        <view class="text-link" data-id="{{item.eventId}}" bindtap="onCopyEvent">复制活动</view>
        <view class="text-link" data-id="{{item.eventId}}" bindtap="onArchiveEvent">归档</view>
        <view class="text-link text-link-warn" data-id="{{item.eventId}}" bindtap="onRepublishEvent">重新发布</view>
      </view>
    </view>
  </block>

  <block wx:elif="{{!loading}}">
    <view class="section-block panel-card empty-state">
      暂时还没有符合当前筛选条件的活动，先去首页创建一个吧。
    </view>
  </block>
</view>
